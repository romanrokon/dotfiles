#!/usr/bin/env swift
import Vision
import Cocoa

let args = CommandLine.arguments
guard args.count >= 2 else {
    FileHandle.standardError.write("usage: macocr <image>\n".data(using: .utf8)!)
    exit(2)
}

let url = URL(fileURLWithPath: args[1])
guard let img = NSImage(contentsOf: url),
      let cg = img.cgImage(forProposedRect: nil, context: nil, hints: nil) else {
    FileHandle.standardError.write("could not load image: \(args[1])\n".data(using: .utf8)!)
    exit(1)
}

let req = VNRecognizeTextRequest { req, _ in
    let obs = req.results as? [VNRecognizedTextObservation] ?? []
    let text = obs.compactMap { $0.topCandidates(1).first?.string }.joined(separator: "\n")
    print(text)
}
req.recognitionLevel = .accurate
req.usesLanguageCorrection = true

let handler = VNImageRequestHandler(cgImage: cg, options: [:])
do {
    try handler.perform([req])
} catch {
    FileHandle.standardError.write("ocr failed: \(error)\n".data(using: .utf8)!)
    exit(1)
}
