<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rzman.aria2</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/aria2c</string>
        <string>--conf-path=/Users/rzman/.aria2/aria2.conf</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/rzman/.aria2/aria2.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/rzman/.aria2/aria2.err.log</string>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
