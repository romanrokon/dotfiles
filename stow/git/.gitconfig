[user]
	email = roman.rokn@gmail.com
	name = romanrokon
[init]
	defaultBranch = main
[core]
	autocrlf = input
   	safecrlf = false
	excludesfile = /Users/rzman/.gitignore_global
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Monokai Extended
